{
  "manifest_version": 3,
  "name": "ScamCap - AI Security Guard",
  "version": "1.0.0",
  "description": "AI-powered protection against phishing attacks and deepfake threats with adaptive MFA security.",
  
  "permissions": [
    "activeTab",
    "storage",
    "background",
    "notifications",
    "webRequest",
    "webRequestBlocking",
    "unlimitedStorage"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background/service-worker.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/content-script.js",
        "content/phishing-detector.js",
        "content/media-scanner.js"
      ],
      "css": ["content/content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ScamCap Security Dashboard",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/*",
        "popup/styles.css",
        "content/warning-overlay.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  
  "options_page": "popup/options.html",
  
  "commands": {
    "quick_scan": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Quick security scan of current page"
    },
    "toggle_protection": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Toggle ScamCap protection on/off"
    }
  },
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-ancestors 'none';"
  }
}
